SMART_DESIGN_ENV=development
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/smart_design
SMART_DESIGN_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

POSTGRES_DB=smart_design
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST_PORT=55432

S3_ENDPOINT=http://127.0.0.1:9000
S3_PREVIEW_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=smart-design-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

SMART_DESIGN_BOOTSTRAP_ADMIN_USERNAME=admin
SMART_DESIGN_BOOTSTRAP_ADMIN_PASSWORD=AIGeek@2025
SMART_DESIGN_BOOTSTRAP_ADMIN_DISPLAY_NAME=System Admin
SMART_DESIGN_BOOTSTRAP_ADMIN_EMAIL=admin@example.local
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_API_CORS_ALLOW_ORIGIN=*

KKFILEVIEW_ENABLED=true
KKFILEVIEW_BASE_URL=http://127.0.0.1:8012
KKFILEVIEW_IMAGE=ymlisoft/kkfileview:4.4.0-12
KKFILEVIEW_KEY=

CLAW_EXECUTABLE_PATH=D:\tools\claw.exe
AGENT_MAX_GLOBAL_CONCURRENCY=4
AGENT_MAX_USER_CONCURRENCY=1
AGENT_JOB_TIMEOUT_SECONDS=900

DOCUMENT_CONVERSION_ENABLED=true
SMART_DESIGN_PLUGIN_STORAGE_DIR=
SMART_DESIGN_PLUGIN_HMAC_SECRET=
SMART_DESIGN_PLUGIN_MAX_PACKAGE_BYTES=52428800
SMART_DESIGN_3D_MODEL_UPLOAD_MAX_BYTES=2147483648
DOCUMENT_CONVERSION_MAX_BYTES=524288000
DOCUMENT_CONVERSION_WORKDIR=
DOCUMENT_CONVERTER_BASE_IMAGE=swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/python:3.12-slim
DEBIAN_APT_MIRROR=https://mirrors.ustc.edu.cn
RUSTUP_INIT_URL=https://mirrors.ustc.edu.cn/rust-static/rustup/dist/x86_64-unknown-linux-gnu/rustup-init
RUSTUP_DIST_SERVER=https://mirrors.ustc.edu.cn/rust-static
RUSTUP_UPDATE_ROOT=https://mirrors.ustc.edu.cn/rust-static/rustup
CARGO_REGISTRY_MIRROR=sparse+https://mirrors.ustc.edu.cn/crates.io-index/
NPM_REGISTRY=https://registry.npmmirror.com
RVMPARSER_REPOSITORY_REF=master
SPARK_REPOSITORY_URL=https://github.com/sparkjsdev/spark.git
SPARK_REPOSITORY_REF=main
RVM_CONVERTER_COMMAND=python /workspace/backend/tools/rvm_to_spark_ply.py --input {input} --output {output} --workdir {workdir}
SPARK_BUILD_LOD_COMMAND=python /workspace/backend/tools/spark_build_lod.py --input {input} --output {output} --quality --rad-chunked
