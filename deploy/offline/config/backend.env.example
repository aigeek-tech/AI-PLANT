SMART_DESIGN_ENV=production
SMART_DESIGN_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
SMART_DESIGN_BOOTSTRAP_ADMIN_USERNAME=admin
SMART_DESIGN_BOOTSTRAP_ADMIN_PASSWORD=AIGeek@2025
SMART_DESIGN_BOOTSTRAP_ADMIN_DISPLAY_NAME=System Admin
SMART_DESIGN_BOOTSTRAP_ADMIN_EMAIL=admin@example.local

S3_REGION=us-east-1
KKFILEVIEW_ENABLED=true
KKFILEVIEW_BASE_URL=http://127.0.0.1:8012
KKFILEVIEW_KEY=

DOCUMENT_CONVERSION_ENABLED=true
SMART_DESIGN_PLUGIN_STORAGE_DIR=/workspace/plugins
SMART_DESIGN_PLUGIN_HMAC_SECRET=
SMART_DESIGN_PLUGIN_MAX_PACKAGE_BYTES=52428800
DOCUMENT_CONVERSION_MAX_BYTES=524288000
DOCUMENT_CONVERSION_WORKDIR=/tmp/smart-design-document-conversion
RVM_CONVERTER_COMMAND=python /workspace/backend/tools/rvm_to_spark_ply.py --input {input} --output {output} --workdir {workdir}
SPARK_BUILD_LOD_COMMAND=python /workspace/backend/tools/spark_build_lod.py --input {input} --output {output} --quality
SPARK_BUILD_LOD_BIN=/opt/spark-cli/rust/target/release/build-lod

CLAW_EXECUTABLE_PATH=
AGENT_MAX_GLOBAL_CONCURRENCY=4
AGENT_MAX_USER_CONCURRENCY=1
AGENT_JOB_TIMEOUT_SECONDS=900
